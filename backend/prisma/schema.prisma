datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

model usuario {
  id     Int     @id @default(autoincrement())
  nome   String
  email  String  @unique
  senha  String

  treinos treino[]
}

model exercicio {
  id            Int     @id @default(autoincrement())
  nome          String  @unique
  descricao     String?

  grupoMuscular String?
  equipamento   String?

  treinoExercicios treinoExercicio[]
}

model treino {
  id        Int  @id @default(autoincrement())
  diaSemana Int  // 1 = segunda, 7 = domingo

  usuarioId Int
  usuario   usuario @relation(fields: [usuarioId], references: [id])

  exercicios treinoExercicio[]
}

model treinoExercicio {
  id Int @id @default(autoincrement())

  treinoId    Int
  exercicioId Int

  series     Int
  repeticoes Int
  cargaKg    Float?
  descanso   Int?

  treino    treino    @relation(fields: [treinoId], references: [id])
  exercicio exercicio @relation(fields: [exercicioId], references: [id])

  @@unique([treinoId, exercicioId])
}