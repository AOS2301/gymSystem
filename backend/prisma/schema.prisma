datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

model usuario {
  id     Int     @id @default(autoincrement())
  nome   String
  email  String  @unique
  senha  String

  treinos treino[]
}

model treino {
  id        Int      @id @default(autoincrement())
  nome      String
  diaSemana Int      // 1 = segunda, 7 = domingo

  usuarioId Int
  usuario   usuario @relation(fields: [usuarioId], references: [id])

  atividades treinoAtividade[]
}

model atividade {
  id        Int     @id @default(autoincrement())
  nome      String
  descricao String?

  treinos treinoAtividade[]
}

model treinoAtividade {
  id Int @id @default(autoincrement())

  treinoId    Int
  atividadeId Int

  series                 Int
  repeticoes             Int
  tempoDescansoSegundos  Int

  treino    treino    @relation(fields: [treinoId], references: [id])
  atividade atividade @relation(fields: [atividadeId], references: [id])

  @@unique([treinoId, atividadeId])
}