datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

model usuario {
  id     Int     @id @default(autoincrement())
  nome   String
  email  String  @unique
  senha  String

  treinos treino[]
}

model exercicio {
  id            Int     @id @default(autoincrement())
  nome          String  @unique
  descricao     String?

  grupo_muscular String?
  equipamento   String?

  treino_exercicio treino_exercicio[]
}

model treino {
  id          Int @id @default(autoincrement())
  dia_semana  Int

  usuario_id  Int
  usuario     usuario @relation(fields: [usuario_id], references: [id])

  exercicios  treino_exercicio[]
}

model treino_exercicio {
  id Int @id @default(autoincrement())

  treino_id    Int
  exercicio_id Int

  series     Int
  repeticoes_min Int
  repeticoes_max Int
  peso    Float?
  descanso   Int?
  ordem      Int

  treino    treino    @relation(fields: [treino_id], references: [id])
  exercicio exercicio @relation(fields: [exercicio_id], references: [id])

  @@unique([treino_id, exercicio_id])
  @@index([treino_id, ordem])
}